# =============================================================================
# FIWARE Configuration
# =============================================================================
FIWARE_BASE_URL=https://imiq-public.et.uni-magdeburg.de/api/orion
FIWARE_API_KEY=your_fiware_api_key_here

# =============================================================================
# OpenAI Configuration (GPT-5.4)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Neo4j Configuration (Neo4j Aura)
# =============================================================================
# Sign up at: https://neo4j.com/cloud/aura/ (FREE tier available)
# Use neo4j+s:// for secure cloud connection
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# For local Neo4j (development only):
# NEO4J_URI=neo4j://127.0.0.1:7687
# NEO4J_PASSWORD=local_password

# =============================================================================
# OpenRouteService Configuration
# =============================================================================
ORS_API_KEY=your_ors_api_key_here
ORS_BASE_URL=https://api.openrouteservice.org

# =============================================================================
# HuggingFace — use cached models, skip online checks
# =============================================================================
HF_HUB_OFFLINE=1

# =============================================================================
# Application Settings
# =============================================================================
MAX_CONVERSATION_HISTORY=6
HTTP_TIMEOUT=10

# Semantic cache — set false for strict multi-turn correctness
SEMANTIC_CACHE_ENABLED=false
# SEMANTIC_CACHE_THRESHOLD=0.88
# SEMANTIC_CACHE_TTL=3600
# SEMANTIC_CACHE_MAX_SIZE=500

# =============================================================================
# Magdeburg Coordinates (for geocoding focus)
# =============================================================================
MAGDEBURG_LAT=52.1205
MAGDEBURG_LON=11.6276

# =============================================================================
# Agent (single GPT-5.4 ReAct agent owns all 15 tools in-process)
# =============================================================================
SINGLE_AGENT_MODEL=gpt-5.4
AGENT_TIMEOUT=90
AGENT_VERBOSE_LOGGING=false

# =============================================================================
# Optional: Redis for distributed rate limiting (multi-worker deployments)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0
